# Backend environment configuration.
# Copy this file to .env on each machine (local PC or server).
# Never commit Backend/.env to GitHub.

# MySQL credentials (used by Docker Compose and local development).
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=chat_app

# SQLAlchemy connection string for local uvicorn (outside Docker).
DATABASE_URL=mysql+pymysql://root:your_mysql_root_password@localhost:3306/chat_app

# OpenAI credentials used only by the backend.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Comma-separated list of allowed frontend origins for CORS.
# Local dev: http://localhost:5173
# Docker on server (port 80): http://YOUR_SERVER_IP
CORS_ORIGINS=http://localhost:5173

# Host and port used when starting uvicorn locally.
APP_HOST=0.0.0.0
APP_PORT=8000
