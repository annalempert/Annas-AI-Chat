# Backend environment configuration example.
# Copy this file to .env and fill in your real values.

# SQLAlchemy connection string for MySQL.
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/chat_app

# OpenAI credentials used only by the backend.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173

# Host and port used when starting uvicorn locally.
APP_HOST=0.0.0.0
APP_PORT=8000
