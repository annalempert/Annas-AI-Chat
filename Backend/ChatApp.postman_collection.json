{
  "info": {
    "name": "Chat App API",
    "_postman_id": "6f3c6b6c-2e90-4a96-a372-5f4f5bf4f191",
    "description": "Postman collection for the ChatGPT-like study API. Includes health check, conversation CRUD, message retrieval, and chat endpoints. Set baseUrl to your backend address and conversationId after creating a conversation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      }
    },
    {
      "name": "Create Conversation",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": {
          "raw": "{{baseUrl}}/api/conversations",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conversations"]
        }
      }
    },
    {
      "name": "List Conversations",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/conversations",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conversations"]
        }
      }
    },
    {
      "name": "Get Conversation Messages",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/messages",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conversations", "{{conversationId}}", "messages"]
        }
      }
    },
    {
      "name": "Delete Conversation",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/conversations/{{conversationId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "conversations", "{{conversationId}}"]
        }
      }
    },
    {
      "name": "Chat",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"conversationId\": null,\n  \"userMessage\": \"Hello assistant\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/chat",
          "host": ["{{baseUrl}}"],
          "path": ["api", "chat"]
        }
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "conversationId", "value": "" }
  ]
}

